import java.util.Scanner;

public class Phone {
    private String name, teln; // 이 Phone 클래스에서만 사용할 수 있도록 접근 제한자 설정
    public Phone(String name, String teln) {
        this.name = name;
        this.teln = teln;
    } // 전체적으로 사용할 이름과 전화번호 생성
}

public String getName() { return name; }
public String getTeln() { return teln; }
// 받은 이름과 전화번호를 저장

public static void main (String[] args) {
    Scanner scanner = new Scanner(System.in);
    Phone phone[] = new Phone[2]; // 이름과 전화번호를 하나의 배열 안으로 저장

    for (int i = 0; i < phone.length; i++) // 배열의 길이 만큼 반복
    {
        System.out.print("이름과 전화번호 입력 >> ");
        String name = scanner.next();
        String teln = scanner.next();

        phone[i] = new Phone(name, teln) // 입력한 이름과 전화번호를 배열에 순차적으로 저장
    }
    
    for (int i = 0; i < phone.length; i ++) // 배열에 저장한 값들을 출력
    {
        System.out.println(phone[i].getName() + "의 번호 " + phone[i].getTeln());
    }
    
    scanner.close();
}

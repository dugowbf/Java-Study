import java.util.Scanner;

class PhoneN { // 전화번호를 저장하기 위한 클래스 생성
    private String name, tel; // 이름과 전화번호를 저장하는 멤버변수

    public PhoneN(String name, String tel) {
        this.name = name;
        this.tel = tel;
        // 입력 받은 이름과 전화번호를 해당 멤버 변수에 저장
    }

    public String getName() { // 입력 받은 이름 반환
        return name;
    }

    public String getTel() { // 입력 받은 전화번호 반환
        return tel;
    }
}

public class PhoneManager {

    public static void main(String[] args) {
        
        Scanner scanner = new Scanner(System.in);
        System.out.print("인원수 >> ");

        int num = scanner.nextInt();
        PhoneN [] phone = new PhoneN[num]; // 입력 받은 인원 수 만큼의 배열 생성

        for (int i = 0; i < num; i++) { // 입력 받은 인원 수 만큼 반복
            System.out.print("이름과 전화번호 입력 >> ");
            String name = scanner.next();
            String tel = scanner.next();

            phone[i] = new PhoneN(name, tel); // 입력 받은 값들을 배열에 저장
        }
    }
}
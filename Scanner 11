import java.util.Scanner;

class Rect {
    private int width, height; // 너비와 높이를 저장하는 멤버 변수

    public Rect(int width, int height) {
        this.width = width;
        this.height = height;
        //입력 받은 너비와 높이를 해당 멤버 변수에 저장
    }

    public int getArea() { return width * height; }
    // 입력 받은 너비와 높이를 가지고 계산하여 반환
}
public class RectArray {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        Rect[] rect = new Rect[4]; // 4개의 사각형을 저장하기 위한 배열
        int sum = 0; // 사각형의 전체 합 변수

        for (int i = 0; int < rect.length; i++) { // 배열의 길이 만큼 반복
            System.out.print((i + 1) + " 너비와 높이 >> ");
            int width = scanner.nextInt();
            int height = scanner.nextInt();

            rect[i] = new Rect(width, height); // 하나씩 사각형의 면적을 저장
            sum += rect[i].getArea(); // 각 사각형의 전체 합을 누적
        }
        
        System.out.println("저장하였습니다... ");
        System.out.println("사각형의 전체 합은 : " + sum);
    }
}